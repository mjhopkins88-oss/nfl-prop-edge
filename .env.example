# --- Database (OPTIONAL for V1) -----------------------------------------
# V1 renders entirely from mock data + bundled fixtures. The dashboard,
# prop detail pages, and /backtest page all work without DATABASE_URL.
#
# Set DATABASE_URL only if you intend to run:
#   - prisma migrate / db push / db seed
#   - scripts/run-backtest-2025.ts against persisted data
#   - the ingestion scripts in --execute mode that log to ApiUsageLog
#
# On Railway, attaching a Postgres plugin injects DATABASE_URL
# automatically — but the deploy itself does NOT require it.
# DATABASE_URL="postgresql://user:password@localhost:5432/nfl_prop_edge?schema=public"

# --- Paid API access (OPTIONAL, OFF by default) -------------------------
# The Odds API client refuses real calls unless BOTH:
#   - the ingestion script is invoked with --execute
#   - ALLOW_REAL_ODDS_API_CALLS=true is exported in the environment
# Leave both unset for safe dry-run-only behavior.
# ALLOW_REAL_ODDS_API_CALLS=false
# ODDS_API_KEY=
