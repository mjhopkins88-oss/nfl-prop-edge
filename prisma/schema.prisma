// Prisma schema for NFL Prop Edge (V1).
// V1 covers lower-variance player props only — see PropType enum.
//
// Shape: PropMarket is the canonical identity of a market (player + game +
// propType + line). Each book or exchange contributes PropQuotes against
// that market. Our model writes Projections, grouped by ModelRun for
// versioning and history. BacktestResult stores per-model evaluation
// aggregates by prop type / season / week.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Position {
  QB
  RB
  WR
  TE
}

enum PropType {
  PASSING_ATTEMPTS
  PASSING_COMPLETIONS
  PASSING_YARDS
  RECEPTIONS
  RECEIVING_YARDS
  RUSHING_ATTEMPTS
  RUSHING_YARDS
}

enum Recommendation {
  OVER
  UNDER
  PASS
}

enum ModelRunType {
  SCHEDULED
  MANUAL
  BACKTEST
}

enum BetResult {
  WIN
  LOSS
  PUSH
  NO_BET
}

model Team {
  id           String   @id @default(cuid())
  abbreviation String   @unique
  name         String
  city         String
  conference   String
  division     String

  players      Player[]
  homeGames    Game[]   @relation("HomeTeam")
  awayGames    Game[]   @relation("AwayTeam")
}

model Player {
  id        String   @id @default(cuid())
  fullName  String
  position  Position
  jersey    Int?
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])

  props     PropMarket[]
  gameLogs  GameLog[]

  @@index([teamId])
  @@index([position])
}

model Game {
  id         String   @id @default(cuid())
  season     Int
  week       Int
  kickoff    DateTime
  homeTeamId String
  awayTeamId String
  homeTeam   Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])

  props      PropMarket[]

  @@index([season, week])
}

/// One market = one (player, game, propType, line). Different lines for
/// the same player/game/propType are separate markets (e.g. alt lines).
/// Quotes attach to a market and let us track every book's price.
model PropMarket {
  id           String   @id @default(cuid())
  playerId     String
  gameId       String
  propType     PropType
  line         Float
  marketKey    String   @unique
  source       String
  snapshotTime DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  player       Player        @relation(fields: [playerId], references: [id])
  game         Game          @relation(fields: [gameId], references: [id])
  quotes       PropQuote[]
  projections  Projection[]

  @@unique([playerId, gameId, propType, line])
  @@index([propType])
  @@index([snapshotTime])
}

/// One quote = one sportsbook (or Kalshi) pricing the over/under on a
/// PropMarket at a point in time. Stores raw American odds plus both
/// the per-side implied probability and the no-vig (de-juiced) version.
model PropQuote {
  id                      String     @id @default(cuid())
  propMarketId            String
  bookName                String
  overPrice               Int
  underPrice              Int
  overImpliedProbability  Float
  underImpliedProbability Float
  noVigOverProbability    Float
  noVigUnderProbability   Float
  quoteTime               DateTime
  createdAt               DateTime   @default(now())

  propMarket              PropMarket @relation(fields: [propMarketId], references: [id])

  @@index([propMarketId, quoteTime])
  @@index([bookName])
}

/// One projection = one model's view of a PropMarket at a point in time.
/// A market accumulates many Projections over its lifetime (line moves,
/// new model versions, mid-week refreshes). modelRunId ties projections
/// back to the run that produced them.
model Projection {
  id                    String         @id @default(cuid())
  propMarketId          String
  modelRunId            String
  projectedMean         Float
  projectedStdDev       Float
  modelOverProbability  Float
  modelUnderProbability Float
  edge                  Float
  expectedValue         Float
  recommendation        Recommendation
  confidence            Float
  qualified             Boolean
  reasons               Json
  risks                 Json
  createdAt             DateTime       @default(now())

  propMarket            PropMarket     @relation(fields: [propMarketId], references: [id])
  modelRun              ModelRun       @relation(fields: [modelRunId], references: [id])

  @@index([propMarketId, createdAt])
  @@index([modelRunId])
  @@index([qualified, edge])
}

/// One ModelRun = one execution of the projection model. Groups every
/// Projection (and Backtest aggregates) it produced.
model ModelRun {
  id        String       @id @default(cuid())
  name      String
  version   String
  runType   ModelRunType
  notes     String?
  createdAt DateTime     @default(now())

  projections     Projection[]
  backtestResults BacktestResult[]
  predictions     PropPrediction[]
  betCandidates   BetCandidate[]

  @@index([version])
  @@index([createdAt])
}

/// One PropPrediction = the model's full evaluation of one prop market
/// at one moment, with grading attached once the actual stat is known.
/// Captured for every prop the engine sees — qualified or not — so we
/// can study calibration on the props we passed on as well.
model PropPrediction {
  id                    String         @id @default(cuid())
  modelRunId            String
  season                Int
  week                  Int
  gameId                String
  team                  String
  playerName            String
  propType              PropType
  line                  Float
  bookName              String
  overPrice             Int
  underPrice            Int
  projectedMean         Float
  projectedStdDev       Float
  modelOverProbability  Float
  modelUnderProbability Float
  bookOverProbability   Float
  bookUnderProbability  Float
  edge                  Float
  expectedValue         Float
  recommendation        Recommendation
  confidence            Float
  qualified             Boolean
  reasons               Json
  risks                 Json
  passReasons           Json
  actualValue           Float?
  result                BetResult?
  unitsStaked           Float?
  unitsReturned         Float?
  brierComponent        Float?
  clvCents              Float?
  createdAt             DateTime       @default(now())

  modelRun              ModelRun       @relation(fields: [modelRunId], references: [id])
  betCandidate          BetCandidate?  @relation("PredictionBetCandidate")

  @@index([modelRunId, season, week])
  @@index([propType])
  @@index([result])
}

/// One BetCandidate = one qualified prediction we'd actually wager on.
/// 1:0..1 from PropPrediction (only qualified predictions promote into a
/// candidate). Kept as its own row so the bet ledger is easy to query.
model BetCandidate {
  id                String         @id @default(cuid())
  predictionId      String         @unique
  modelRunId        String
  season            Int
  week              Int
  gameId            String
  playerName        String
  propType          PropType
  line              Float
  recommendedSide   Recommendation
  recommendedOdds   Int
  edge              Float
  expectedValue     Float
  confidence        Float
  staked            Float
  returned          Float?
  result            BetResult?
  createdAt         DateTime       @default(now())

  prediction        PropPrediction @relation("PredictionBetCandidate", fields: [predictionId], references: [id])
  modelRun          ModelRun       @relation(fields: [modelRunId], references: [id])

  @@index([modelRunId, season, week])
  @@index([propType])
}

/// Backtest aggregate: one row per (model run, prop type, season, week).
model BacktestResult {
  id          String   @id @default(cuid())
  modelRunId  String
  propType    PropType
  season      Int
  week        Int
  plays       Int
  wins        Int
  losses      Int
  pushes      Int
  unitsStaked Float
  unitsReturn Float
  roiPct      Float
  hitRate     Float
  createdAt   DateTime @default(now())

  modelRun    ModelRun @relation(fields: [modelRunId], references: [id])

  @@unique([modelRunId, propType, season, week])
  @@index([propType, season, week])
}

model GameLog {
  id                  String   @id @default(cuid())
  playerId            String
  season              Int
  week                Int
  opponentAbbr        String
  passingAttempts     Int      @default(0)
  passingCompletions  Int      @default(0)
  passingYards        Int      @default(0)
  receptions          Int      @default(0)
  receivingYards      Int      @default(0)
  rushingAttempts     Int      @default(0)
  rushingYards        Int      @default(0)

  player              Player   @relation(fields: [playerId], references: [id])

  @@index([playerId, season, week])
}

/// One row per external API call. Used to track real credit burn vs
/// estimates and to detect runaway scripts before they spend through a
/// budget. Most fields are nullable because not every source reports
/// every value (Open-Meteo has no credit headers; Kalshi has none).
model ApiUsageLog {
  id                String   @id @default(cuid())
  source            String
  endpoint          String
  requestUrlHash    String
  estimatedCredits  Int?
  actualCredits     Int?
  creditsRemaining  Int?
  creditsUsed       Int?
  creditsLast       Int?
  status            Int?
  message           String?
  createdAt         DateTime @default(now())

  @@index([source, createdAt])
  @@index([requestUrlHash])
}

/// One row per paid Odds-API ingestion (smoke, week-subset,
/// week-full). Audit trail for what was paid for. Never carries
/// secrets — only credit counts + metadata.
model OddsIngestionRun {
  id                String   @id @default(cuid())
  season            Int
  week              Int?
  scope             String
  status            String
  startedAt         DateTime
  finishedAt        DateTime?
  creditsEstimated  Int?
  creditsUsed       Int?
  creditsRemaining  Int?
  marketsRequested  Int?
  gamesRequested    Int?
  errorMessage      String?
  rawResultJson     Json?
  createdAt         DateTime @default(now())

  @@index([season, week, createdAt])
  @@index([status, createdAt])
}

/// Canonical per-row stored odds — the table form of
/// data/processed/odds/{season}/week-{N}-prop-markets.csv. The
/// migration helper writes both file and table so a redeploy
/// can rehydrate the file from the DB.
model StoredPropMarket {
  id              String   @id @default(cuid())
  season          Int
  week            Int
  gameId          String
  eventId         String?
  marketKey       String
  playerName      String
  playerId        String?
  team            String
  opponent        String
  propType        String
  line            Float
  sportsbook      String
  overOdds        Float
  underOdds       Float
  snapshotTime    String?
  oddsSource      String?
  isBeforeKickoff Boolean  @default(true)
  createdAt       DateTime @default(now())

  /// Re-running the migration produces the same (season, week,
  /// marketKey, sportsbook, snapshotTime) tuple. Upsert on this
  /// key so a redeploy doesn't duplicate the file's contents.
  @@unique([season, week, marketKey, sportsbook, snapshotTime])
  @@index([season, week, gameId])
  @@index([season, week, playerName])
}

/// Full stored-mode backtest output. One row per run; the page
/// fetches the most recent `(season, week, dataMode)` entry.
/// JSON columns hold opaque payloads — never secrets.
model StoredBacktestRun {
  id                          String   @id @default(cuid())
  season                      Int
  week                        Int
  dataMode                    String
  status                      String
  realWeek1BacktestReady      Boolean
  scheduleValidationStatus    String?
  syntheticFixture            Boolean
  candidatesJson              Json?
  resultsJson                 Json?
  v1v2Json                    Json?
  parlayJson                  Json?
  gameEdgeJson                Json?
  createdAt                   DateTime @default(now())

  @@index([season, week, createdAt])
  @@index([dataMode, createdAt])
}

/// Single-row table for the admin ingestion state. We pin
/// `id = "singleton"` so reads are deterministic — no listing
/// to find the latest row, no race window for two writers.
model AdminIngestionState {
  id                          String   @id @default("singleton")
  smokeSucceededAt            DateTime?
  smokeCreditsUsed            Int?
  week1IngestionSucceededAt   DateTime?
  week1SubsetSucceededAt      DateTime?
  week1SubsetCreditsUsed      Int?
  lastAction                  String?
  lastResultJson              Json?
  lastTimestamp               DateTime?
  lastSummary                 String?
  updatedAt                   DateTime @updatedAt
}
