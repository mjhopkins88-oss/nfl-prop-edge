tsconfig.tsbuildinfo

# ingestion outputs — generated by scripts/ingest-nfl-history.ts
# (raw nflverse CSVs and the processed bundle are reproducible
# from the script, so we keep the directories tracked via .gitkeep
# but exclude everything inside.)
data/raw/*
!data/raw/.gitkeep
!data/raw/nfl/
!data/raw/nfl/.gitkeep
data/raw/nfl/*
!data/raw/nfl/.gitkeep
data/processed/*
!data/processed/.gitkeep
!data/processed/nfl/
!data/processed/nfl/.gitkeep
data/processed/nfl/*
!data/processed/nfl/.gitkeep
data/backtests/**
!data/backtests/.gitkeep
!data/backtests/2025/
!data/backtests/2025/.gitkeep
# Week 1 starter-test fixture outputs ship with the repo so the
# deployed /backtest/week-1 page has data on a fresh build.
!data/backtests/2025/week-1-*.fixture.json

# Build-time deployment manifest — regenerated on every build.
data/deployment-manifest.json
data/cache/**
!data/cache/.gitkeep

# Admin ingestion state — runtime persistence, never committed.
data/admin/**
!data/admin/.gitkeep
data/admin-ingestion/**
!data/admin-ingestion/.gitkeep

# python
__pycache__/
*.pyc
.venv/
venv/
